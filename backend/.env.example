DATABASE_URL=postgresql://user:password@host:5432/dbname
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: only required for GitHub Models. A GitHub personal access token with the "models:read" scope: https://github.com/settings/tokens
GITHUB_MODELS_TOKEN=your-github-pat-here
# Optional: only required for Groq (free) models. Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
# Optional: only required for Cerebras (free) models. Get one at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here
# Optional: only required for OpenRouter models. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Optional: comma-separated CORS allowlist. Defaults to the production
# frontend origin plus http://localhost:3000 and http://localhost:3001.
CORS_ORIGINS=
